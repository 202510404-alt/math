<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>이커머스 풀필먼트 SCM 최적화 시뮬레이터</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$','$$'], ['\\[','\\]']]
            },
            chtml: {
                scale: 1.15
            }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

    <style>
        body { 
            font-family: 'Malgun Gothic', sans-serif; 
            margin: 20px; 
            display: flex; 
            gap: 30px; 
            background-color: #f8fafc; 
        }
        .control-panel { 
            width: 35%; 
            background: white; 
            padding: 25px; 
            border-radius: 12px; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.05); 
            height: fit-content;
        }
        .chart-panel { 
            width: 62%; 
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        h3 { 
            margin-top: 0; 
            color: #1e3a8a; 
            border-bottom: 2px solid #e2e8f0; 
            padding-bottom: 8px; 
        }
        .slider-group { 
            margin-bottom: 15px; 
        }
        label { 
            display: block; 
            font-weight: bold; 
            margin-bottom: 5px; 
            font-size: 14px; 
        }
        input[type=range] { 
            width: 100%; 
        }
        .val-display { 
            float: right; 
            color: #2563eb; 
            font-weight: bold; 
        }
        .dashboard { 
            display: flex; 
            gap: 10px; 
        }
        .card { 
            flex: 1; 
            background: #eff6ff; 
            padding: 12px; 
            border-radius: 8px; 
            text-align: center; 
            border: 1px solid #bfdbfe; 
        }
        .card h4 { 
            margin: 0 0 5px 0; 
            font-size: 12px; 
            color: #1e40af; 
        }
        .card p { 
            margin: 0; 
            font-size: 16px; 
            font-weight: bold; 
            color: #1d4ed8; 
        }
        .card.alert { 
            background: #fff1f2; 
            border-color: #fecdd3; 
        }
        .card.alert h4 { 
            color: #9f1239; 
        }
        .card.alert p { 
            color: #b91c1c; 
        }
        .chart-box {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        
        .formula-panel {
            background: #f1f5f9;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid #cbd5e1;
        }
        .formula-title {
            font-size: 15px;
            font-weight: bold;
            color: #334155;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .formula-box{
            background:#fff;
            padding:20px;
            border-radius:8px;
            border:1px solid #e2e8f0;
            overflow-x:auto;
        }
                
        .formula-desc {
            font-size: 13px;
            color: #475569;
            line-height: 1.5;
        }
        .highlight {
            color: #2563eb;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="control-panel">
    <h3>📦 시스템 인프라 설정 (국토부 가이드)</h3>
    <div class="slider-group">
        <label>Center Scale (센터 규모): <span id="v_scale" class="val-display">2</span>단계</label>
        <input type="range" id="scale" min="1" max="5" value="2" oninput="updateChart()">
    </div>
    <div class="slider-group">
        <label>Automation Rate (자동화율): <span id="v_auto_rate" class="val-display">40</span>%</label>
        <input type="range" id="auto_rate" min="0" max="100" value="40" oninput="updateChart()">
    </div>

    <br>
    <h3>👥 물류 현장 인력 설정 (고용부 기준)</h3>
    <div class="slider-group">
        <label>Labor Count (투입 인력): <span id="v_l_count" class="val-display">10</span>명</label>
        <input type="range" id="l_count" min="1" max="40" value="10" oninput="updateChart()">
    </div>
</div>

<div class="chart-panel">
    <div class="dashboard">
        <div class="card">
            <h4>초기 설립 비용 (CAPEX)</h4>
            <p id="d_init">0만 원</p>
        </div>
        <div class="card" id="card_bep">
            <h4>손익분기점 (BEP)</h4>
            <p id="d_bep">-</p>
        </div>
        <div class="card">
            <h4>투자 수익률 (ROI)</h4>
            <p id="d_roi">0%</p>
        </div>
        <div class="card">
            <h4>최종 누적 순이익</h4>
            <p id="d_net">0만 원</p>
        </div>
    </div>

    <div class="chart-box">
        <h2>Ecommerce Fulfillment Center SCM Optimization</h2>
        <canvas id="factoryChart" width="800" height="320"></canvas>
    </div>

    <div class="formula-panel">
        <div class="formula-title">🧮 생산성 및 비용 구조 수리적 모델링 (대수 단원 복합 연계)</div>
        <div class="formula-box" id="formula_display">
            </div>
        <div class="formula-desc">
            <b>[인력 생산성]</b> 현장 인원 과다 투입 시 동선 마찰 및 한계 손실을 고려해 <b>공차가 음수인 등차수열의 합 모델</b>을 구축했습니다.<br>
            <b>[자동화 생산성]</b> 장비 증설에 따른 한계 수용 한계를 반영해 <b>상승폭이 감쇠하는 등차수열의 합 모델</b>을 결합했습니다.<br>
            <b>[SCM Trade-off]</b> 자동화 단계 상승 시, 실제 투입 인력의 유효 인건비가 <b>일정 비율(등비수열)로 차감</b>되는 대체 경제학 모델을 완성했습니다.
        </div>
    </div>
</div>

<script>
    const YEARS = 10;
    
    const REAL_DATA = {
        baseCost: 45000,
        laborFirstTerm: 500,     // 인력 1인 초기 생산성
        laborCommonDiff: -15,    // 인력 증가에 따른 패널티 (음의 공차 등차수열)
        autoFirstTerm: 600,      // 자동화 1단계 초기 효율
        autoCommonDiff: -40,     // 자동화 고도화에 따른 한계체감 공차
        laborWage: 360,          // 기본 인당 연봉
        replacementRate: 0.88    // 자동화 1단계당 실질 인건비 절감 비율 (등비수열 인자)
    };

    const ctx = document.getElementById('factoryChart').getContext('2d');
    
    let factoryChart = new Chart(ctx, {
        type: 'line',
        data: {
            labels: ["설립 초기", ...Array.from({length: YEARS}, (_, i) => `${i + 1}년차`)],
            datasets: [{ 
                label: '센터 누적 순이익 흐름', 
                borderColor: '#2563eb', 
                backgroundColor: 'rgba(37, 99, 235, 0.05)', 
                data: [], 
                fill: true, 
                tension: 0.1 
            }]
        },
        options: { 
            responsive: true, 
            scales: { y: { title: { display: true, text: '누적 금액 (만원)' } } } 
        }
    });

    // 등차수열의 합 계산 함수
    function calculateArithmeticSum(n, a, d) {
        if (n <= 0) return 0;
        let total = 0;
        for (let i = 1; i <= n; i++) {
            total += (a + (i - 1) * d);
        }
        return total;
    }

    function updateChart() {
        // ============================
        // 슬라이더 값 읽기
        // ============================
        const scale = parseInt(document.getElementById("scale").value);
        const auto_rate = parseInt(document.getElementById("auto_rate").value);
        const l_count = parseInt(document.getElementById("l_count").value);

        document.getElementById("v_scale").innerText = scale;
        document.getElementById("v_auto_rate").innerText = auto_rate;
        document.getElementById("v_l_count").innerText = l_count;

        // ============================
        // 초기 투자비(CAPEX)
        // ============================
        const buildingCost = REAL_DATA.baseCost * scale;
        const automationCost = auto_rate * 600 * scale;
        const initialCost = buildingCost + automationCost;

        // ============================
        // 생산성 계산 (등차수열 기반 한계체감 모델)
        // ============================
        // 1. 인력 생산성 (음의 공차 등차합)
        const totalLaborEff = calculateArithmeticSum(l_count, REAL_DATA.laborFirstTerm, REAL_DATA.laborCommonDiff);

        // 2. 자동화 생산성 (감쇠형 등차합)
        const autoStage = auto_rate === 0 ? 0 : Math.ceil(auto_rate / 10);
        const totalAutoEff = calculateArithmeticSum(autoStage, REAL_DATA.autoFirstTerm, REAL_DATA.autoCommonDiff) * scale;

        // 시스템 총 하루 주문 처리량
        const dailyOrders = Math.max(0, totalLaborEff + totalAutoEff);

        // ============================
        // 매출 계산
        // ============================
        const operatingDays = 300;
        const profitPerOrder = 0.35;
        const annualRevenue = dailyOrders * operatingDays * profitPerOrder;

        // ============================
        // 운영비 계산 (자동화율에 따른 인건비 대체 - 등비 모델 융합)
        // ============================
        // 자동화 단계가 높아질수록 인당 실질 인건비 부담이 등비수열 비율로 감소함
        const effectiveWage = REAL_DATA.laborWage * Math.pow(REAL_DATA.replacementRate, autoStage);
        const laborCost = l_count * effectiveWage;

        const maintenanceCost = auto_rate * 25 * scale;
        const facilityCost = scale * 2500;
        const annualExpense = laborCost + maintenanceCost + facilityCost;

        // ============================
        // 연간 순이익
        // ============================
        const annualNetProfit = annualRevenue - annualExpense;

        // ============================
        // 수식 실시간 렌더링 (대수 단원 복합 증명)
        // ============================
        const formulaElement = document.getElementById("formula_display");
        formulaElement.innerHTML = 
            "$$" +
            "\\begin{aligned}" +
            "\\text{Labor Eff (음의 등차합)} &= \\sum_{i=1}^{" + l_count + "} \\left[ 500 + (i - 1) \\times (-15) \\right] \\\\" +
            "\\text{Auto Eff (감쇠형 등차합)} &= \\left( \\sum_{j=1}^{" + autoStage + "} \\left[ 600 + (j - 1) \\times (-40) \\right] \\right) \\times " + scale + " \\\\" +
            "\\text{Effective Wage (등비수열 차감)} &= 360 \\times 0.88^{" + autoStage + "}" +
            "\\end{aligned}" +
            "$$";

        if (window.MathJax && MathJax.typesetPromise) {
            MathJax.typesetClear([formulaElement]);
            MathJax.typesetPromise([formulaElement]);
        }

        // ============================
        // 10년 시뮬레이션
        // ============================
        let cumulative_profits = [];
        let currentBalance = -initialCost;
        let bepYear = -1;

        cumulative_profits.push(Math.round(currentBalance));

        for (let year = 1; year <= YEARS; year++) {
            currentBalance += annualNetProfit;
            cumulative_profits.push(Math.round(currentBalance));

            if (currentBalance >= 0 && bepYear === -1) {
                bepYear = year;
            }
        }

        // ============================
        // 대시보드 출력
        // ============================
        document.getElementById("d_init").innerText = initialCost.toLocaleString() + "만 원";

        const bepCard = document.getElementById("card_bep");
        if (bepYear !== -1) {
            document.getElementById("d_bep").innerText = bepYear + "년차";
            bepCard.classList.remove("alert");
        } else {
            document.getElementById("d_bep").innerText = "10년 내 회수 불가";
            bepCard.classList.add("alert");
        }

        const roi = (currentBalance / initialCost) * 100;
        document.getElementById("d_roi").innerText = roi.toFixed(1) + "%";
        document.getElementById("d_net").innerText = Math.round(currentBalance).toLocaleString() + "만 원";

        // ============================
        // 그래프 갱신
        // ============================
        factoryChart.data.datasets[0].data = cumulative_profits;
        factoryChart.update();
    }

    updateChart();
</script>

</body>
</html>